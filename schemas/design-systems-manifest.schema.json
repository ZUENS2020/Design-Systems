{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://design-systems.pages.dev/schemas/design-systems-manifest.schema.json",
  "title": "Design Systems Manifest",
  "type": "object",
  "required": [
    "site",
    "generatedAt",
    "systemCount",
    "systems"
  ],
  "properties": {
    "site": {
      "type": "object",
      "required": ["title", "origin"],
      "properties": {
        "title": { "type": "string" },
        "origin": { "type": "string" }
      },
      "additionalProperties": true
    },
    "generatedAt": { "type": "string" },
    "systemCount": { "type": "integer", "minimum": 0 },
    "systems": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "slug",
          "name",
          "title",
          "summary",
          "tags",
          "themes",
          "urls"
        ],
        "properties": {
          "id": { "type": "string" },
          "slug": { "type": "string" },
          "name": { "type": "string" },
          "title": { "type": "string" },
          "summary": { "type": "string" },
          "tags": { "type": "array", "items": { "type": "string" } },
          "themes": { "type": "array", "items": { "type": "string" } },
          "urls": {
            "type": "object",
            "required": ["detail", "raw"],
            "properties": {
              "detail": { "type": "string" },
              "raw": { "type": "string" }
            },
            "additionalProperties": true
          }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
